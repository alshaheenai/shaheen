# Al-Shaheen reverse proxy + automatic HTTPS (Let's Encrypt).
# Requires: ports 80/443 reachable, and DNS for alshaheenai.com / www pointing
# directly at this server in **DNS-only** mode (Cloudflare grey cloud), so Caddy
# can complete the ACME challenge and manage its own certificate.

alshaheenai.com {
	reverse_proxy app:3000
}

www.alshaheenai.com {
	redir https://alshaheenai.com{uri} permanent
}
